{
    "name": "pasangin/backend",
    "type": "project",
    "description": "Backend API untuk Aplikasi Pasangin",
    "homepage": "https://pasangin.co.id",
    "license": "proprietary",
    "require": {
        "php": "^8.1",
        "codeigniter4/framework": "^4.0",
        "dompdf/dompdf": "^3.1",
        "codeigniter4/shield": "^1.3",
        "kreait/firebase-php": "^7.0",
        "phpoffice/phpspreadsheet": "^5.7",
        "zircote/swagger-php": "^6.1"
    },
    "require-dev": {
        "fakerphp/faker": "^1.9",
        "mikey179/vfsstream": "^1.6",
        "phpunit/phpunit": "^9.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app",
            "Config\\": "app/Config"
        },
        "classmap": [
            "app/ThirdParty"
        ],
        "exclude-from-classmap": [
            "**/Database/Migrations/**"
        ]
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "platform": {
            "php": "8.2.0"
        }
    }
}
